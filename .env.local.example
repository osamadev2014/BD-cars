# =============================================
# Ryon - Local Development Environment (Template)
# =============================================
# Copy this file to .env.local and fill in the values.
# Run: cp .env.local.example .env.local
#
# After running `supabase start`, you will see the
# actual anon key and service role key in the output.
# Replace the PLACEHOLDER values below with those.

# Supabase Local (from `supabase start` output)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=PASTE_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=PASTE_SERVICE_ROLE_KEY_HERE

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=BD
NEXT_PUBLIC_DEFAULT_LOCALE=ar
NEXT_PUBLIC_SUPPORTED_LOCALES=ar,en

# Development OTP
DEV_OTP=1234
DEV_SESSION_SECRET=local-dev-secret-do-not-use-in-production

# Stripe (disabled in dev - placeholder values)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Email (disabled in dev)
RESEND_API_KEY=re_placeholder
NOTIFICATION_FROM_EMAIL=noreply@dev.local

# SMS (disabled in dev)
TWILIO_ACCOUNT_SID=AC_placeholder
TWILIO_AUTH_TOKEN=placeholder
TWILIO_PHONE_NUMBER=+966500000000

# Push Notifications (disabled in dev)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=VAPID_placeholder
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@local
