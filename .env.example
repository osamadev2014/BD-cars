# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
NEXT_PUBLIC_APP_NAME=BD
NEXT_PUBLIC_DEFAULT_LOCALE=ar
NEXT_PUBLIC_SUPPORTED_LOCALES=ar,en

# Development OTP (always 1234 in dev)
DEV_OTP=1234

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Notifications - Email
RESEND_API_KEY=re_...
NOTIFICATION_FROM_EMAIL=noreply@ryon.sa

# Notifications - SMS
TWILIO_ACCOUNT_SID=AC_...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+966...

# Notifications - Web Push (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=VAPID_...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:support@ryon.sa
