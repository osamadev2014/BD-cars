# =============================================
# Ryon - Production Environment (Template)
# =============================================
# This is a reference for production deployment.
# NEVER commit real production keys to version control.
# Use your hosting provider's environment variable manager.

# Supabase (from Supabase Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_APP_NAME=BD
NEXT_PUBLIC_DEFAULT_LOCALE=ar
NEXT_PUBLIC_SUPPORTED_LOCALES=ar,en

# Development OTP (set to empty in production)
DEV_OTP=
DEV_SESSION_SECRET=GENERATE_A_STRONG_SECRET_HERE

# Stripe (from Stripe Dashboard)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email - Resend (from Resend Dashboard)
RESEND_API_KEY=re_...
NOTIFICATION_FROM_EMAIL=noreply@your-domain.com

# SMS - Twilio (from Twilio Console)
TWILIO_ACCOUNT_SID=AC_...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+966...

# Push Notifications - VAPID (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:support@your-domain.com
